{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/fabric/schema/credential.json",
  "title": "Credential",
  "description": "A verifiable credential or attestation about an Identity \u2014 a claim issued by one party about another, optionally cryptographically provable.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "description": "Credential type, e.g. EmailVerified, EmployeeRole."
    },
    "claim": {
      "type": "object"
    },
    "proof": {
      "type": "string",
      "description": "Signature / proof for tamper-evidence."
    }
  },
  "required": [
    "id",
    "type"
  ]
}
