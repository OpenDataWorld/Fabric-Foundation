{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/fabric/schema/pipeline.json",
  "title": "Pipeline",
  "description": "A batch or streaming flow that moves and transforms data between sources and datasets.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "name"
  ]
}
