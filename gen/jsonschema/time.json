{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/fabric/schema/time.json",
  "title": "Time",
  "description": "The temporal primitive: instants, intervals, durations, recurrences, and validity windows. Time underpins Events, temporal Constraints, State transitions, and the auditability of everything that happens.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "description": "instant | interval | duration | recurrence | window"
    },
    "instant": {
      "type": "string",
      "format": "date-time"
    },
    "start": {
      "type": "string",
      "format": "date-time"
    },
    "end": {
      "type": "string",
      "format": "date-time"
    },
    "duration": {
      "type": "string"
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone, e.g. UTC, Europe/London."
    }
  },
  "required": [
    "id",
    "kind"
  ]
}
