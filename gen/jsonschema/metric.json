{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/fabric/schema/metric.json",
  "title": "Metric",
  "description": "A measurable indicator with a value and unit, used to judge Objectives.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "name"
  ]
}
