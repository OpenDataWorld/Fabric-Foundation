{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/fabric/schema/dataset.json",
  "title": "Dataset",
  "description": "A named, governed collection of data \u2014 the core asset of the fabric.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "format": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "name"
  ]
}
